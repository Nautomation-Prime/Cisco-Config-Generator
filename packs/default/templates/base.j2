! ============================================================
! Base Configuration
! Device  : {{ device.hostname }}
! Site    : {{ device.site | default('N/A', true) }}
! Model   : {{ device.model }}
! Generated by Cisco Config Generator - Nautomation Prime
! ============================================================
!
service password-encryption
service timestamps log datetime msec localtime show-timezone
service timestamps debug datetime msec localtime show-timezone
no service pad
!
hostname {{ device.hostname }}
!
ip domain-name {{ global.domain_name | default('local', true) }}
!
{% if global.dns_servers %}
{% for dns in global.dns_servers %}
ip name-server {{ dns }}
{% endfor %}
{% endif %}
!
! --- Timezone ---
clock timezone {{ device.timezone | default('GMT', true) }} 0 0
!
! --- NTP ---
{% if global.ntp_servers %}
{% for ntp in global.ntp_servers %}
ntp server {{ ntp }}
{% endfor %}
{% endif %}
!
! --- Local Authentication ---
{% if global.local_username %}
username {{ global.local_username }} privilege 15 secret {{ global.local_password | default('changeme', true) }}
{% endif %}
enable secret {{ global.enable_secret | default('changeme', true) }}
!
! --- AAA ---
{% if global.aaa_server %}
aaa new-model
aaa authentication login default group tacacs+ local
aaa authorization exec default group tacacs+ if-authenticated
!
tacacs server PRIMARY
 address ipv4 {{ global.aaa_server }}
 key {{ global.aaa_key | default('changeme', true) }}
!
{% else %}
no aaa new-model
!
{% endif %}
! --- SSH ---
crypto key generate rsa modulus 2048
ip ssh version 2
ip ssh time-out 60
ip ssh authentication-retries 3
!
! --- Console & VTY Lines ---
line con 0
 exec-timeout 10 0
 logging synchronous
 login local
!
line vty 0 15
 exec-timeout 10 0
 logging synchronous
 login local
 transport input ssh
!
! --- Logging ---
logging buffered 16384
logging console critical
{% if global.syslog_server %}
logging host {{ global.syslog_server }}
{% endif %}
!
! --- SNMP v3 ---
{% if global.snmp_v3_user %}
snmp-server group {{ global.snmp_v3_group if global.snmp_v3_group else 'MONITORING' }} v3 priv
snmp-server user {{ global.snmp_v3_user }} {{ global.snmp_v3_group if global.snmp_v3_group else 'MONITORING' }} v3 auth {{ global.snmp_v3_auth_protocol }} {{ global.snmp_v3_auth_password }} priv {{ global.snmp_v3_priv_protocol }} {{ global.snmp_v3_priv_password }}
{% if global.snmp_host %}
snmp-server host {{ global.snmp_host }} version 3 priv {{ global.snmp_v3_user }}
{% endif %}
snmp-server enable traps
{% endif %}
!
! --- Spanning Tree ---
spanning-tree mode rapid-pvst
spanning-tree extend system-id
spanning-tree portfast bpduguard default
!
! --- CDP / LLDP ---
cdp run
lldp run
!
! --- HTTP ---
no ip http server
no ip http secure-server
!
! --- Management Interface ---
interface Vlan{{ device.mgmt_vlan }}
 description ** Management **
 ip address {{ device.mgmt_ip }} {{ device.mgmt_subnet | default('255.255.255.0', true) }}
 no shutdown
!
ip default-gateway {{ device.default_gateway }}
!
! --- Banner ---
banner motd ^
{{ global.banner_motd | default('AUTHORISED ACCESS ONLY. Disconnect immediately if not authorised.', true) }}
^
!
