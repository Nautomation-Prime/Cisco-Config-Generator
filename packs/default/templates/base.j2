! ============================================================
! Base Configuration
! Device  : {{ device.hostname }}
! Site    : {{ device.site | default('N/A', true) }}
! Model   : {{ device.model }}
! Generated by Cisco Config Generator - Nautomation Prime
! ============================================================
!
no service pad
service tcp-keepalives-in
service tcp-keepalives-out
service timestamps debug datetime msec localtime show-timezone
service timestamps log datetime msec localtime show-timezone
service password-encryption
service compress-config
service call-home
!
hostname {{ device.hostname }}
!
vrf definition Mgmt-vrf
 !
 address-family ipv4
 exit-address-family
 !
 address-family ipv6
 exit-address-family
!
logging count
logging buffered 128000
logging rate-limit all 100
logging console informational
logging monitor informational
logging origin-id hostname
logging trap informational
!
errdisable recovery cause bpduguard
errdisable recovery cause storm-control
errdisable recovery cause udld
errdisable recovery cause gbic-invalid
errdisable recovery interval 1800
!
enable secret 9 {{ global.enable_secret }}
{% if global.local_username %}
username {{ global.local_username }} privilege 15 secret 9 {{ global.local_password }}
{% endif %}
!
aaa new-model
!
aaa authentication fail-message #
{% if global.aaa_fail_message %}
{{ global.aaa_fail_message }}
{% else %}
  **************************- WARNING - ************************
  *                                                            *
  *   Your attempt to access this system/network has failed.   *
  *                                                            *
  *   If you are an unauthorized person, LOG OFF IMMEDIATELY   *
  *                                                            *
  *   Unauthorized access to this system/network is            *
  *                                                            *
  *   strictly prohibited!                                     *
  *                                                            *
  ************************* - WARNING - ************************
{% endif %}
#
!
{% if global.tacacs_server_1 %}
aaa group server tacacs+ {{ global.aaa_group_name | default('TACACS_SERVERS', true) }}
 server-private {{ global.tacacs_server_1 }} key 7 {{ global.tacacs_key }}
{% if global.tacacs_server_2 %}
 server-private {{ global.tacacs_server_2 }} key 7 {{ global.tacacs_key }}
{% endif %}
ip tacacs source-interface Vlan{{ device.mgmt_vlan }}
!
aaa authentication password-prompt Local-Password:
aaa authentication username-prompt Local-Login-Name:
aaa authentication login default group {{ global.aaa_group_name | default('TACACS_SERVERS', true) }} local
aaa authentication enable default group {{ global.aaa_group_name | default('TACACS_SERVERS', true) }} enable
aaa authorization exec default group {{ global.aaa_group_name | default('TACACS_SERVERS', true) }} local
aaa authorization console
aaa authorization commands 15 default group {{ global.aaa_group_name | default('TACACS_SERVERS', true) }} local
aaa accounting exec default start-stop group {{ global.aaa_group_name | default('TACACS_SERVERS', true) }}
aaa accounting commands 15 default start-stop group {{ global.aaa_group_name | default('TACACS_SERVERS', true) }}
aaa session-id common
{% else %}
aaa authentication login default local
aaa authorization exec default local if-authenticated
{% endif %}
!
clock timezone {{ device.timezone | default('GMT', true) }} {{ device.timezone_hours_offset | default(0, true) }} {{ device.timezone_minutes_offset | default(0, true) }}
{% if global.summer_time_config %}
clock summer-time {{ global.summer_time_config }}
{% endif %}
!
{% if 'C92' in device.model or 'C93' in device.model %}
boot system flash:packages.conf
{% endif %}
no call-home
no ip routing
!
{% if global.dns_servers %}
{% for dns in global.dns_servers %}
ip name-server {{ dns }}
{% endfor %}
{% endif %}
no ip domain lookup
ip domain name {{ global.domain_name | default('local', true) }}
ip domain lookup source-interface Vlan{{ device.mgmt_vlan }}
!
crypto key generate rsa label SEC2048 general-keys modulus 2048
ip ssh version 2
ip ssh rsa keypair-name SEC2048
ip ssh dh min size 2048
ip ssh server algorithm mac hmac-sha1
ip ssh time-out 15
ip ssh source-interface Vlan{{ device.mgmt_vlan }}
!
no ip dhcp snooping
no ip dhcp snooping vlan 1-4094
!
ip dhcp snooping
ip dhcp snooping vlan 1-4094
no ip dhcp snooping information option
!
login on-success log
login on-failure log
!
vtp mode off
udld enable
no device-tracking logging theft
!
{% if 'C92' in device.model or 'C93' in device.model %}
license boot level network-essentials addon dna-essentials
!
diagnostic bootup level complete
!
{% endif %}
spanning-tree mode rapid-pvst
spanning-tree extend system-id
spanning-tree portfast bpduguard default
!
{% if 'C92' in device.model or 'C93' in device.model %}
redundancy
 mode sso
!
{% endif %}
transceiver type all
 monitoring
!
! --- VLAN 1 Shutdown ---
interface Vlan1
 description * unused *
 no ip address
 shutdown
!
! --- Management Interface ---
interface Vlan{{ device.mgmt_vlan }}
 description {{ device.site | default('Management', true) }} - Management
 ip address {{ device.mgmt_ip }} {{ device.mgmt_subnet | default('255.255.255.0', true) }}
 no shutdown
!
ip default-gateway {{ device.default_gateway }}
ip forward-protocol nd
no ip http server
no ip http authentication local
no ip http secure-server
!
{% if global.syslog_server %}
logging host {{ global.syslog_server }}
!
{% endif %}
{% if global.snmp_ro_user or global.snmp_rw_user %}
snmp-server view VIEWALL iso included
snmp-server trap link ietf
snmp ifmib ifindex persist
{% if global.snmp_ro_user %}
{% if features.acls and global.snmp_ro_acl %}
snmp-server group {{ global.snmp_ro_group | default('SNMPv3_RO', true) }} v3 priv read VIEWALL access {{ global.snmp_ro_acl }}
{% else %}
snmp-server group {{ global.snmp_ro_group | default('SNMPv3_RO', true) }} v3 priv read VIEWALL
{% endif %}
{% endif %}
{% if global.snmp_rw_user %}
{% if features.acls and global.snmp_rw_acl %}
snmp-server group {{ global.snmp_rw_group | default('SNMPv3_RW', true) }} v3 priv read VIEWALL write VIEWALL access {{ global.snmp_rw_acl }}
{% else %}
snmp-server group {{ global.snmp_rw_group | default('SNMPv3_RW', true) }} v3 priv read VIEWALL write VIEWALL
{% endif %}
{% endif %}
{% if global.snmp_location %}
snmp-server location {{ global.snmp_location }}
{% endif %}
{% if global.snmp_contact %}
snmp-server contact {{ global.snmp_contact }}
{% endif %}
snmp-server enable traps
{% if global.snmp_ro_user %}
snmp-server user {{ global.snmp_ro_user }} {{ global.snmp_ro_group | default('SNMPv3_RO', true) }} v3 auth {{ global.snmp_auth_protocol | default('SHA', true) }} {{ global.snmp_ro_auth_password }} priv {{ global.snmp_priv_protocol | default('AES', true) }} 256 {{ global.snmp_ro_priv_password }}
{% endif %}
{% if global.snmp_rw_user %}
snmp-server user {{ global.snmp_rw_user }} {{ global.snmp_rw_group | default('SNMPv3_RW', true) }} v3 auth {{ global.snmp_auth_protocol | default('SHA', true) }} {{ global.snmp_rw_auth_password }} priv {{ global.snmp_priv_protocol | default('AES', true) }} 256 {{ global.snmp_rw_priv_password }}
{% endif %}
{% if global.snmp_host %}
snmp-server host {{ global.snmp_host }} version 3 priv {{ global.snmp_ro_user if global.snmp_ro_user else global.snmp_rw_user }}
{% endif %}
!
{% endif %}
line con 0
 exec-timeout 15 0
 logging synchronous
 escape-character 3
 stopbits 1
!
line vty 0 4
 exec-timeout 15 0
{% if features.acls and global.vty_acl %}
 access-class {{ global.vty_acl }} in vrf-also
{% endif %}
 length 20
 logging synchronous
 transport input ssh
 escape-character 3
!
line vty 5 15
 exec-timeout 15 0
{% if features.acls and global.vty_acl %}
 access-class {{ global.vty_acl }} in vrf-also
{% endif %}
 length 20
 logging synchronous
 transport input ssh
 escape-character 3
!
{% if global.ntp_servers %}
{% for ntp in global.ntp_servers %}
ntp server {{ ntp }}
{% endfor %}
!
{% endif %}
banner motd ^
{{ global.banner_motd | default('AUTHORISED ACCESS ONLY. Disconnect immediately if not authorised.', true) }}
^
!
