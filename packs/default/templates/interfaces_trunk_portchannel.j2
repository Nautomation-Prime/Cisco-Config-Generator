! ============================================================
! Trunk Uplink with Port-Channel Configuration
! ============================================================
!
{% for iface in interfaces %}
interface {{ iface.interface_name }}
 description {{ iface.description if iface.description else '** Uplink (Port-Channel) **' }}
 switchport mode trunk
 switchport trunk native vlan {{ iface.native_vlan if iface.native_vlan else settings.defaults.native_vlan | default(1, true) }}
 switchport trunk allowed vlan {{ iface.allowed_vlans if iface.allowed_vlans else 'all' }}
 switchport nonegotiate
 load-interval 30
 storm-control broadcast level {{ iface.storm_control_broadcast if iface.storm_control_broadcast else ('0.10 0.07' if iface.interface_name.startswith('TenGigabit') else '1.00 0.70') }}
 storm-control multicast level {{ iface.storm_control_multicast if iface.storm_control_multicast else ('0.10 0.07' if iface.interface_name.startswith('TenGigabit') else '1.00 0.70') }}
 ip dhcp snooping trust
 channel-group {{ iface.port_channel_number }} mode active
 no shutdown
!
{% endfor %}
{% for port_channel_number, members in interfaces | groupby('port_channel_number') %}
{% set port_channel = members | first %}
interface Port-channel{{ port_channel_number }}
 description {{ port_channel.description if port_channel.description else '** Uplink (Port-Channel) **' }}
 switchport mode trunk
 switchport trunk allowed vlan {{ port_channel.allowed_vlans if port_channel.allowed_vlans else 'all' }}
 switchport trunk native vlan {{ port_channel.native_vlan if port_channel.native_vlan else settings.defaults.native_vlan | default(1, true) }}
 switchport nonegotiate
 load-interval 30
 storm-control broadcast level {{ port_channel.storm_control_broadcast if port_channel.storm_control_broadcast else ('0.10 0.07' if port_channel.interface_name.startswith('TenGigabit') else '1.00 0.70') }}
 storm-control multicast level {{ port_channel.storm_control_multicast if port_channel.storm_control_multicast else ('0.10 0.07' if port_channel.interface_name.startswith('TenGigabit') else '1.00 0.70') }}
 ip dhcp snooping trust
!
{% endfor %}
